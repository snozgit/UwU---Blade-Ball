    hexBox.TextTransparency = 0.4
    hexBox.TextSize = 11
    hexBox.Font = Enum.Font.GothamBold
    hexBox.BorderSizePixel = 0
    hexBox.ZIndex = 202
    hexBox.Parent = previewRow
    Instance.new("UICorner", hexBox).CornerRadius = UDim.new(0,6)

    local H, S, V = Color3.toHSV(currentColor)

    local function colorToHex(c)
        return string.format("#%02x%02x%02x",
            math.floor(c.R*255),
            math.floor(c.G*255),
            math.floor(c.B*255))
    end

    local function applyColor(h, s, v)
        H, S, V = h, s, v
        local col = Color3.fromHSV(H, S, V)
        -- FIX 1 : met à jour la couleur de fond du canvas (teinte pure)
        svFrame.BackgroundColor3 = Color3.fromHSV(H, 1, 1)
        swatch.BackgroundColor3 = col
        previewSw.BackgroundColor3 = col
        hexBox.Text = colorToHex(col)

        if which == "accent1" then
            _ACCENT1 = col
        else
            _ACCENT2 = col
        end
        applyTheme()
        titleGrad.Color = ColorSequence.new(_ACCENT1, _ACCENT2)
    end

    -- Init curseurs
    svCursor.Position = UDim2.new(S, 0, 1-V, 0)
    hueCursor.Position = UDim2.new(H, 0, 0.5, 0)
    svFrame.BackgroundColor3 = Color3.fromHSV(H, 1, 1)

