            local relY = math.clamp((inp.Position.Y - svFrame.AbsolutePosition.Y)/svFrame.AbsoluteSize.Y, 0, 1)
            svCursor.Position = UDim2.new(relX, 0, relY, 0)
            applyColor(H, relX, 1-relY)
        end
    end)
    svBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then svDrag = false end
    end)

    -- ── DRAG HUE ─────────────────────────────────
    local hueDrag = false
    local hueBtn = Instance.new("TextButton")
    hueBtn.Size = UDim2.new(1,0,1,0)
    hueBtn.BackgroundTransparency = 1
    hueBtn.Text = ""
    hueBtn.ZIndex = 206
