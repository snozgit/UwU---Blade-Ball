    svCursor.BorderSizePixel = 0
    svCursor.ZIndex = 210
    svCursor.Parent = svFrame
    Instance.new("UICorner", svCursor).CornerRadius = UDim.new(1,0)
    local svcs = Instance.new("UIStroke", svCursor)
    svcs.Color = Color3.fromRGB(0,0,0); svcs.Transparency = 0.5; svcs.Thickness = 1.5

    -- ── HUE BAR ──────────────────────────────────
    local hueBar = Instance.new("Frame")
    hueBar.Size = UDim2.new(1,-20,0,16)
    hueBar.Position = UDim2.new(0,10,0,174)
    hueBar.BorderSizePixel = 0
    hueBar.ZIndex = 201
    hueBar.ClipsDescendants = true
    hueBar.Parent = popup
    Instance.new("UICorner", hueBar).CornerRadius = UDim.new(1,0)

    local hueGrad = Instance.new("UIGradient")
    hueGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    Color3.fromRGB(255,0,0)),
        ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,165,0)),
