    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = item

    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0,46,0,18)
    valLbl.Position = UDim2.new(1,-60,0,8)
    valLbl.BackgroundColor3 = _ACCENT1
    valLbl.BackgroundTransparency = 0.85
    valLbl.Text = tostring(default)
    valLbl.TextColor3 = _ACCENT1
    valLbl.TextSize = 11
    valLbl.Font = Enum.Font.GothamBold
    valLbl.BorderSizePixel = 0
    valLbl.Parent = item
    Instance.new("UICorner", valLbl).CornerRadius = UDim.new(0,6)
    local vs = Instance.new("UIStroke", valLbl)
    vs.Color = _ACCENT1; vs.Transparency = 0.78; vs.Thickness = 1
    regA1(valLbl, "BackgroundColor3")
    regA1(valLbl, "TextColor3")
    regA1(vs, "Color")

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1,-28,0,4)
    track.Position = UDim2.new(0,14,0,38)
    track.BackgroundColor3 = Color3.fromRGB(255,255,255)
    track.BackgroundTransparency = 0.93
    track.BorderSizePixel = 0
    track.Parent = item
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = _ACCENT1
    fill.BorderSizePixel = 0
    fill.Parent = track
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
    local fillGrad = gradient(fill, _ACCENT1, _ACCENT2, 0)
    regGrad(fillGrad)
    regA1(fill, "BackgroundColor3")

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,12,0,12)
    knob.AnchorPoint = Vector2.new(0.5,0.5)
    knob.Position = UDim2.new((default-min)/(max-min),0,0.5,0)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0
    knob.ZIndex = 2
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    local value = default
    local dragging = false

    local function upd(inp)
        local rel = math.clamp((inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        value = math.floor(min + (max-min)*rel)
        fill.Size = UDim2.new(rel,0,1,0)
        knob.Position = UDim2.new(rel,0,0.5,0)
        valLbl.Text = tostring(value)
        if cb then cb(value) end
    end

