local _ACCENT1 = Color3.fromRGB(180, 80, 255)
local _ACCENT2 = Color3.fromRGB(255, 80, 200)
local BG_MAIN   = Color3.fromRGB(19, 19, 23)
local BG_DARK   = Color3.fromRGB(15, 15, 19)
local BG_ITEM   = Color3.fromRGB(26, 26, 32)
local BG_STATUS = Color3.fromRGB(12, 12, 16)

local accentRefs = {}
local gradientRefs = {}

local function regGrad(g, fn)
    if not fn then
        fn = function(a1, a2) return ColorSequence.new(a1, a2) end
    end
    table.insert(gradientRefs, {g, fn})
end

local function applyTheme()
    for _, ref in ipairs(accentRefs) do
        local obj, prop, which = ref[1], ref[2], ref[3]
        if obj and obj.Parent then
            local col = which == "accent1" and _ACCENT1 or _ACCENT2
            pcall(function() obj[prop] = col end)
        end
    end
    for _, ref in ipairs(gradientRefs) do
        local g, fn = ref[1], ref[2]
        if g and g.Parent then
            pcall(function() g.Color = fn(_ACCENT1, _ACCENT2) end)
        end
    end
end

local function regA1(obj, prop) table.insert(accentRefs, {obj, prop, "accent1"}) end
local function regA2(obj, prop) table.insert(accentRefs, {obj, prop, "accent2"}) end

-- ── UTILS ──────────────────────────────────────
local function tween(inst, props, t, style, dir)
    style = style or Enum.EasingStyle.Quad
    dir   = dir   or Enum.EasingDirection.Out
    return TweenService:Create(inst, TweenInfo.new(t or 0.2, style, dir), props)
end

local function gradient(inst, c0, c1, rot)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new(c0, c1)
    g.Rotation = rot or 90
    g.Parent = inst
    return g
end

