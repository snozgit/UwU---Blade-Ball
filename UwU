-- ── COLOR PICKER (HSV) — VERSION CORRIGÉE ──────
--
-- FIX 1 : Canvas SV corrigé avec deux overlays séparés
--   → whiteOverlay : Frame blanc avec gradient de transparence gauche→droite
--   → blackOverlay : Frame noir avec gradient de transparence haut→bas
--   (avant : UIGradient.Color sur svFrame = multiplie la couleur de fond,
--    donc jamais blanc réel)
--
-- FIX 2 : Fermeture au clic en dehors
--   → Un backdrop transparent (ZIndex 198) est créé au-dessus de tout
--     quand le popup s'ouvre. Cliquer dessus ferme le picker.
--   → Le backdrop est détruit à la fermeture.
-- ══════════════════════════════════════════════
local colorRefs = {}
local pickerOpen = nil
local pickerBackdrop = nil  -- bouton fond transparent global

local function closeAllPickers()
    if pickerOpen then
        pickerOpen.Visible = false
        pickerOpen = nil
    end
    if pickerBackdrop then
        pickerBackdrop:Destroy()
        pickerBackdrop = nil
    end
end

