local function GetClosestPlayer()
    local closestDist = math.huge
    local closestTarget = nil
    pcall(function()
        for _, v in pairs(workspace.Alive:GetChildren()) do
            if v and v:FindFirstChild("HumanoidRootPart") and v ~= player.Character then
                local dist = (player.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
                if dist < closestDist then closestDist = dist; closestTarget = v end
            end
        end
    end)
    return closestTarget
end

local function GetBall()
    for _, v in pairs(workspace.Balls:GetChildren()) do
        if v:IsA("Part") then return v end
    end
end

local function getSpeed(part)
    if part:IsA("BasePart") then
        local s = part.Velocity.Magnitude
        if s > 1 then return part, s end
    end
end

