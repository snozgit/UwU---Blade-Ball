    hueBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDrag = true
            local relX = math.clamp((inp.Position.X - hueBar.AbsolutePosition.X)/hueBar.AbsoluteSize.X, 0, 1)
            hueCursor.Position = UDim2.new(relX, 0, 0.5, 0)
            applyColor(relX, S, V)
        end
    end)
    hueBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then hueDrag = false end
    end)

    UIS.InputChanged:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if svDrag then
            local relX = math.clamp((inp.Position.X - svFrame.AbsolutePosition.X)/svFrame.AbsoluteSize.X, 0, 1)
            local relY = math.clamp((inp.Position.Y - svFrame.AbsolutePosition.Y)/svFrame.AbsoluteSize.Y, 0, 1)
            svCursor.Position = UDim2.new(relX, 0, relY, 0)
            applyColor(H, relX, 1-relY)
        end
        if hueDrag then
            local relX = math.clamp((inp.Position.X - hueBar.AbsolutePosition.X)/hueBar.AbsoluteSize.X, 0, 1)
            hueCursor.Position = UDim2.new(relX, 0, 0.5, 0)
            applyColor(relX, S, V)
        end
    end)

    -- ── REPOSITIONNEMENT DU POPUP ─────────────────
    local function repositionColorPopup()
        local abs = swatch.AbsolutePosition
        local siz = swatch.AbsoluteSize
        local screenX = workspace.CurrentCamera.ViewportSize.X
        local screenY = workspace.CurrentCamera.ViewportSize.Y
        local popW, popH = 220, 240

        local posX = math.clamp(abs.X + siz.X/2 - popW/2, 4, screenX - popW - 4)
        local posY = abs.Y + siz.Y + 8
        if posY + popH > screenY - 4 then
            posY = abs.Y - popH - 8
        end
        popup.Position = UDim2.new(0, posX, 0, posY)
    end

    -- ── SWATCH CLICK → OPEN/CLOSE ─────────────────
    local swBtn = Instance.new("TextButton")
    swBtn.Size = UDim2.new(1,0,1,0)
    swBtn.BackgroundTransparency = 1
    swBtn.Text = ""
    swBtn.ZIndex = 203
    swBtn.Parent = swatch
    swBtn.MouseButton1Click:Connect(function()
        local alreadyOpen = (pickerOpen == popup)

        -- Ferme tout d'abord
        closeAllPickers()

        if not alreadyOpen then
            -- FIX 2 : crée le backdrop transparent qui ferme le picker au clic
            local bd = Instance.new("TextButton")
            bd.Size = UDim2.new(1, 0, 1, 0)
            bd.BackgroundTransparency = 1
            bd.Text = ""
            bd.ZIndex = 198   -- derrière le popup (200) mais devant tout le reste
            bd.Parent = ScreenGui
            bd.MouseButton1Click:Connect(function()
                closeAllPickers()
            end)
            pickerBackdrop = bd

            repositionColorPopup()
            popup.Visible = true
            pickerOpen = popup
        end
    end)
end

