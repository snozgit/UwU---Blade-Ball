    previewRow.Size = UDim2.new(1,-20,0,28)
    previewRow.Position = UDim2.new(0,10,0,198)
    previewRow.BackgroundTransparency = 1
    previewRow.ZIndex = 201
    previewRow.Parent = popup

    local previewSw = Instance.new("Frame")
    previewSw.Size = UDim2.new(0,28,0,28)
    previewSw.BackgroundColor3 = currentColor
    previewSw.BorderSizePixel = 0
    previewSw.ZIndex = 202
    previewSw.Parent = previewRow
    Instance.new("UICorner", previewSw).CornerRadius = UDim.new(0,7)

    local hexBox = Instance.new("TextLabel")
